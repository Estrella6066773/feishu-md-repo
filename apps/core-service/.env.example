# core-service 环境变量示例
# 复制为 .env 后按需修改（.env 不会进入 Git）

FEISHU_MD_HOST=127.0.0.1
FEISHU_MD_PORT=8787

# 可选：覆盖本地数据目录（内含 app.db，含飞书凭证，勿提交）
# FEISHU_MD_DATA_DIR=

# 可选：debug | info | warn | error（默认 info）
# FEISHU_MD_LOG_LEVEL=info

# 可选：同步时跨文档正文写入并发数（默认 4，上限 16；单文档内 API 仍串行）
# FEISHU_MD_SYNC_DOC_CONCURRENCY=4
