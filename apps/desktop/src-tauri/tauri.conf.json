{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Feishu MD Repo",
  "version": "0.1.0",
  "identifier": "com.feishu-md.repo",
  "build": {
    "beforeDevCommand": "pnpm --filter @feishu-md/ui dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @feishu-md/ui build",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Feishu MD Repo",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
